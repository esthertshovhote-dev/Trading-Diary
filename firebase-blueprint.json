{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trading record",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "asset": { "type": "string" },
        "side": { "type": "string", "enum": ["Buy", "Sell"] },
        "size": { "type": "string" },
        "entryPrice": { "type": "number" },
        "currentPrice": { "type": "number" },
        "pnl": { "type": "number" },
        "pnlPercent": { "type": "number" },
        "sl": { "type": "number" },
        "tp": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Closed"] },
        "strategy": { "type": "string" },
        "setupScore": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "thumbnails": { "type": "array", "items": { "type": "string" } },
        "annotations": { "type": "object" }
      },
      "required": ["uid", "asset", "side", "entryPrice", "timestamp"]
    },
    "SelfReview": {
      "title": "Self Review",
      "description": "An advanced self-review note",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "period": { "type": "string", "enum": ["day", "week", "month", "quarter", "year"] },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "period", "date", "content"]
    },
    "Strategy": {
      "title": "Strategy",
      "description": "A trading strategy definition",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "direction": { "type": "string" },
        "timeFrame": { "type": "string" },
        "executionTimeFrame": { "type": "string" },
        "confluences": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Trading records collection"
    },
    "/selfReviews/{reviewId}": {
      "schema": "SelfReview",
      "description": "Self-review notes collection"
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Trading strategies collection"
    }
  }
}
